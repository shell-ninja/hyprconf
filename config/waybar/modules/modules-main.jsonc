{
    //_________\\ Default Modules //_________\\

    // taskbar
    "wlr/taskbar": {
		"format": "{icon}",
		"icon-size": 18,
		"icon-theme": "Tela-circle-dracula",
        "spacing": 0,
		"tooltip-format": "{title}",
		"on-click": "activate",
		"on-click-middle": "close",
		"app_ids-mapping": {
			"firefoxdeveloperedition": "firefox-developer-edition"
		}
	},

    // network
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{icon}",
        "format-ethernet": "ˇ░îś",
        "tooltip-format": "Network: <big><b>{essid}</b></big>\nSignal strength: <b>{signaldBm}dBm ({signalStrength}%)</b>\nFrequency: <b>{frequency}MHz</b>\nInterface: <b>{ifname}</b>\nIP: <b>{ipaddr}/{cidr}</b>\nGateway: <b>{gwaddr}</b>\nNetmask: <b>{netmask}</b>\nDownload: <b><span foreground='#99ffdd'>´ÇÖ {bandwidthDownBytes}</span></b>\nUpload: <b><span foreground='#ffcc66'>´éô {bandwidthUpBytes}</span></b>",
        "format-linked": "ˇ░łÇ {ifname} (No IP)",
        "format-disconnected": "ˇ░ľ¬ ",
        "tooltip-format-disconnected": "Disconnected",
        "interval": 2,
        "max-length": 30,
    	"format-icons": [
    		"ˇ░Ą»", "ˇ░Ąč", "ˇ░Ąó", "ˇ░Ąą", "ˇ░ĄĘ"
    	],
        "on-click-right": "kitty -e nmtui"
    },

    // network speed
    "network#speed": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format": "<span foreground='#99ffdd'>´ÇÖ {bandwidthDownBytes}</span> <span foreground='#ffcc66'>´éô {bandwidthUpBytes}</span>",
        "format-disconnected": "ˇ░ľ¬ ",
        "tooltip": false,
        "interval": 1,
        "max-length": 30,
    	"format-icons": [
    		"ˇ░Ą»", "ˇ░Ąč", "ˇ░Ąó", "ˇ░Ąą", "ˇ░ĄĘ"
    	],
        "on-click-right": "kitty -e nmtui"
    },

    // idle inhibitor
    "idle_inhibitor": {
        "format": "{icon}",
        "start-activated": true,
            "format-icons": {
                "activated": "ţ░Ľ",
                "deactivated": "ˇ░ŤŐ"
            },
        "tooltip-format-activated":"Caffeine Mode: Active \nNothing will be happen.",
        "tooltip-format-deactivated":"Caffeine Mode: Inactive\n\nIf there is no interaction with your\nsystem (mouse/keyboard), then \nScreen Lock: after 5 min \nScreen Off: after 10 min \nSleep: after 30 min"
    },

    // window
    "hyprland/window": {
        "format": "{}",
        "separate-outputs": true,
        "rewrite": {
            "(.*)${USER}@${set_sysname}:(.*)": "$1 ´ĺë :$2",
            "(.*) ÔÇö Mozilla Firefox": "$1 ˇ░ł╣",
            "(.*)Mozilla Firefox": "$1 Firefox ˇ░ł╣",
            "(.*) - Visual Studio Code": "$1 ˇ░Ę×",
            "(.*)Visual Studio Code": "$1 Code ˇ░Ę×",
            "(.*) ÔÇö Dolphin": "$1 ˇ░ëő",
            "(.*)Spotify.*": "$1 Spotify ˇ░ôç",
            "(.*)Steam": "$1 Steam ˇ░ôô",
            "(.*) - Discord": "$1 ´ç┐ ",
            "(.*?)-\\s*YouTube(.*)": "$1ˇ░Śâ", 
            "(.*?\\s)YouTube(.*)": "$1YouTube ˇ░Śâ"
        },
        "max-length": 50
    },

    // language
    "hyprland/language": {
        "interval": 1,
        "format": "ţęą {}",
        "format-uk": "Uk",
        "format-en": "US"
    },

    // workspaces
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "on-click": "activate",
        "on-scroll-up": "hyprctl dispatch workspace e-1",
        "on-scroll-down": "hyprctl dispatch workspace e+1",
        "format": "{icon}",
        // "format-icons": {
            // "1": "´äá",
            // "2": "´ëĘ",
            // "3": "´äí",
            // "4": "´ü╗",
        //     "urgent": "´ü¬",
        //     "focused": "´ćĺ",
        //     "default": "´äĹ"
        // },
        "format-icons": {
            // for arch
            // "active": "ˇ░«»",
            // "default": "ţ╗ż"

            // for fedora
            //  "active": "ˇ░úŤ",  
            //  "default": "´äî"

            // for opensuse
            // "active": "´îö",
            // "default": "ţ¬»"
          },
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": []
        }
    },

    //------took it from JaKooLit-------//

    "hyprland/workspaces#preview": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "sort-by-number": true,
        "show-special": false,
        "on-click": "activate",
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1",
        // "persistent-workspaces": {
        //     "*": 5
        //   },
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": []
        },
        "format": "{icon} {windows}",
        "format-window-separator": " ",
        "window-rewrite-default": "´üÖ ",
        "window-rewrite": {		
            "title<.*amazon.*>": "´ë░ ",
            "title<.*reddit.*>": "´Őü ",

            "class<firefox|org.mozilla.firefox|librewolf|floorp|mercury-browser|[Cc]achy-browser>": "ţŁů ",
            "class<zen>": "ˇ░░Ě ",
            "class<waterfox|waterfox-bin>": "ţ║ô ",
            "class<microsoft-edge>": "´Őé ",
            "class<Chromium|Thorium|[Cc]hrome>": "´ëĘ ",
            "class<brave-browser>": "­čŽü ",
            "class<tor browser>": "´Ź▒ ",
            "class<firefox-developer-edition>": "ˇ░ł╣ ",

            "class<kitty>": "ˇ░äŤ ",
            "class<kitty-dropterm>": "´äá ",
            "class<com.mitchellh.ghostty>": " ţ×Ľ",
            "class<org.wezfurlong.wezterm>": " ţ¬ů",

            "class<[Tt]hunderbird|[Tt]hunderbird-esr>": "´Ź░ ",
            "class<eu.betterbird.Betterbird>": "´Ź░ ",
            "title<.*gmail.*>": "ˇ░Őź ",

            "class<[Tt]elegram-desktop|org.telegram.desktop|io.github.tdesktop_x64.TDesktop>": "ţłŚ ",
            "class<discord|[Ww]ebcord|Vesktop>": "´ç┐ ",
            "title<.*whatsapp.*>": "´ł▓ ",
            "title<.*zapzap.*>": "´ł▓ ",
            "title<.*messenger.*>": "´ëč ",
            "title<.*facebook.*>": "´éÜ ",
            "title<.*instagram.*>": "ˇ░őż ",
            "title<.*reddit.*>": "´Őü ",
            "title<.*github.com.*>": "ţťë ",


            "title<.*ChatGPT.*>": "ˇ░Üę ",
            "title<.*deepseek.*>": "ˇ░Üę ",
            "title<.*qwen.*>": "ˇ░Üę ",
            "class<subl>": "ˇ░ů│ ",
            "class<slack>": "´ćś ",

            "class<mpv>": "´Ź« ",
            "class<celluloid|Zoom>": "´ÇŻ ",
            "class<Cider>": "ˇ░Äć ",
            "title<.*Picture-in-Picture.*>": "´öČ ",
            "title<.*youtube.*>": "´ů¬ ",
            "class<vlc>": "ˇ░Ľ╝ ",
            "title<.*cmus.*>": "´Çü ",
            "class<[Ss]potify>": "´ć╝ ",

            "class<virt-manager>": "ţş╗ ",
            "class<.virt-manager-wrapped>": "ţş╗ ",
            "class<virtualbox manager>": "­čĺŻ ",
            "title<virtualbox>": "­čĺŻ ",
            "class<remmina>": "­čľą´ŞĆ ",

            "class<VSCode|code-url-handler|code-oss|codium|codium-url-handler|VSCodium|code>": "ˇ░Ę× ",
            "class<antigravity>": "ţ║ž ",
            "class<dev.zed.Zed>": "ˇ░Áü",
            "class<codeblocks>": "ˇ░ůę ",
            "title<.*github.*>": "´äô ",
            "title<*[Pp]hotopea.*>": "ţ×Ş ",
            "class<mousepad>": "´ůť ",
            "class<libreoffice-writer>": "ţÜą ",
            "class<libreoffice-startcenter>": "ˇ░Ćć ",
            "class<libreoffice-calc>": "´Ź╗ ",
            "title<.*nvim ~.*>": "´Ź» ",
            "title<.*vim.*>": "ţčů ",
            "title<.*nvim.*>": "ţčů ",
            "title<.*figma.*>": "ţŻç ",
            "title<.*jira.*>": "ţŁť ",
            "class<jetbrains-idea>": "ţ×Á ",

            "class<obs|com.obsproject.Studio>": "ţ«ž ",

            "class<polkit-gnome-authentication-agent-1>": "ˇ░ĺâ ",
            "class<nwg-look>": "ţşĺ ",
            "class<[Pp]avucontrol|org.pulseaudio.pavucontrol>": "ˇ▒íź ",
            "class<steam>": "´ćÂ ",
            "class<thunar|nemo|org.kde.dolphin>": "ˇ░Ł░ ",	
            "class<Gparted>":"´âç",
            "class<gimp>": "´îŞ ",
            "class<emulator>": "­čô▒ ",
            "class<android-studio>": "´ů╗ ",
            "class<org.pipewire.Helvum>": "ˇ░ôâ",
            "class<localsend>":"´çá",
            "class<PrusaSlicer|UltiMaker-Cura|OrcaSlicer>": "ˇ░╣Ť",
            "class<org.bleachbit.BleachBit>": "´çŞ "
            }
        },

    // cpu
    "cpu": {
        "interval": 10,
        "format": "{icon0}{icon1}{icon2}{icon3}{icon4} {usage}%",
        "format-icons": ["Ôľü", "Ôľé", "Ôľâ", "Ôľä", "Ôľů", "Ôľć", "Ôľç", "Ôľł"]
    },

    // memory
    "memory": {
        "interval": 2,
        "format": "ˇ░żů {used}GB",
        "max-length": 10,
        "tooltip": true,
        "tooltip-format": "ţëŽ {used:0.1f}GB/{total:0.1f}GB"
    },

    // dik
    "disk": {
        "interval": 30,
        "format": "´âç {free}",
        "path": "/",
        "tooltip": true,
        "tooltip-format": "Storage - {used} used out of {total} on {path} ({percentage_used}%)"
    },

    // temperature
    "temperature": {
        "thermal-zone": 1,
        "format": "´őë {temperatureC}┬░C",
        "critical-threshold": 70,
        "format-critical": "´őç {temperatureF}┬░F",
        "on-click": "kitty --title btop sh -c 'btop'"
    },
    
    // backlight
    "backlight": {
        "interval": 2,
        "align": 0,
        "rotate": 0,
        "format": "{icon} {percent}%",
        "format-icons": [
            "ţĆĽ ",
            "ţĆŚ ",
            "ţĆÜ ",
            "ˇ░âŁ ",
            "ˇ░â× ",
            "ˇ░âč ",
            "ˇ░âá "
        ],
        "tooltip-format": "backlight {percent}%",
        "icon-size": 10,
        "on-click": "",
        "on-click-middle": "",
        "on-click-right": "",
        "on-update": "",
        "on-scroll-up": "~/.config/hypr/scripts/brightness.sh up",
        "on-scroll-down": "~/.config/hypr/scripts/brightness.sh down",
        "smooth-scrolling-threshold": 1
    },

    // tray
    "tray": {
        "icon-size": 18,
        "spacing": 10
    },

    // clock
    "clock": {
        "format": "´ÇŚ {:%I:%M %p}",
        "format-alt": "´ÇŚ {:%R ˇ░âş %d┬Ě%m┬Ě%Y}",
        "on-clock-right": "exec gnome-calendar",
        "tooltip": true,
        "tooltip-format": "<span>{calendar}</span>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "on-scroll": 1,
            "on-click-right": "mode",
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b>{}</b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_down",
            "on-scroll-down": "shift_up"
        }
    },

    // battery
    "battery": {
	//"interval": 5,
	"align": 0,
	"rotate": 0,
	"full-at": 100,
	"design-capacity": false,
	"states": {
		"good": 95,
		"warning": 30,
		"critical": 15
	},
	"format": "{icon} {capacity}%",
	"format-charging": "´âž {capacity}%",
	"format-plugged": "ˇ▒śľ {capacity}%",
	"format-alt-click": "click",
	"format-full": "{icon} Full",
	"format-alt": "{icon} {time}",
	"format-icons": [
		"ˇ░éÄ", "ˇ░ü║", "ˇ░ü╗", "ˇ░ü╝", "ˇ░üŻ", "ˇ░üż", "ˇ░ü┐", "ˇ░éÇ", "ˇ░éü", "ˇ░éé", "ˇ░ü╣"
	    ],
	"format-time": "{H}h {M}min",
	"tooltip": true,
	"tooltip-format": "{timeTo} {power}w",
    },

    "pulseaudio/slider": {
        "min": 0,
        "max": 100,
        "on-scroll-up": "~/.config/hypr/scripts/volumecontrol.sh --inc",
        "on-scroll-down": "~/.config/hypr/scripts/volumecontrol.sh --dec",
        "orientation": "vertical"
    },

    // pulseaudio
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "´ĹŽ ",
        "tooltip": false,
        "on-click": "~/.config/hypr/scripts/volumecontrol.sh --toggle",
        "on-click-right": "pavucontrol",
        "on-scroll-up": "~/.config/hypr/scripts/volumecontrol.sh --inc",
        "on-scroll-down": "~/.config/hypr/scripts/volumecontrol.sh --dec",
        "scroll-step": 5,
        "format-icons": {
            "headphone": "´Çą",
            "hands-free": "´Çą",
            "headset": "´Çą",
            "phone": "´éĽ",
            "default": ["´ÇŽ", "´Çž", "´ÇĘ "]
        }
    },

    // pulseautio mic
    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "´ä░ {volume}%",
        "format-source-muted": "´ä▒ ",
        "on-click": "pamixer --default-source -t",
        "on-click-right": "pavucontrol",
        "on-scroll-up": "pamixer --default-source -i 5",
        "on-scroll-down": "pamixer --default-source -d 5",
        "scroll-step": 5
    },

    // mpris ( media player )
    "mpris": {
        "interval": 2,
        "format": "{player_icon}  {status_icon}",
        "format-paused": "{player_icon}  {status_icon}",
        "tooltip": true,
        "tooltip-format": "{dynamic}",
        "on-click": "playerctl play-pause",
        "on-click-middle": "playerctl previous",
        "on-click-right": "playerctl next",
        "scroll-step": 5.0,
        "on-scroll-up": "~/.config/hypr/scripts/volumecontrol.sh --inc",
        "on-scroll-down": "~/.config/hypr/scripts/volumecontrol.sh --dec",
        "smooth-scrolling-threshold": 1,
        "player-icons": {
            "chromium": "´ëĘ",
            "default": "´ÇŁ",
            "firefox": "´ëę",
            "kdeconnect": "´śč",
            "mopidy": "´Çü",
            "mpv": "ˇ░É╣",
            "spotify": "´ć╝",
            "vlc": "ˇ░Ľ╝"
        },
        "status-icons": {
            "paused": "ˇ░ĆĄ ",
            "playing": "´üő ",
            "stopped": "´üŹ"
        },
        "max-length": 30
    },

    "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
      "tooltip": true,
      "format-icons": {
        "default": "´âž",
        "performance": "ˇ▒ô×",
        "balanced": "´ëÄ",
        "power-saver": "´üČ"
      }
    },

    // "user": {
    //     "format": "{user}",
    //     "interval": 60,
    //     "height": 30,
    //     "width": 30,
    //     "icon": true,
    // },

    // keyboard status
    // "keyboard-state": {
	// "numlock": true,
	// "capslock": true,
	// "format": {
	// 	"numlock": "N {icon}",
	// 	"capslock": "ˇ░¬Ť {icon}"
	//     },
