{
    // all the modules

    // Defaults
    "wlr/taskbar": {
		"format": "{icon}",
		"icon-size": 18,
		"icon-theme": "Tela-circle-dracula",
        "spacing": 0,
		"tooltip-format": "{title}",
		"on-click": "activate",
		"on-click-middle": "close",
		"app_ids-mapping": {
			"firefoxdeveloperedition": "firefox-developer-edition"
		}
	},

    "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
      "tooltip": true,
      "format-icons": {
        "default": "ïƒ§",
        "performance": "ïƒ§",
        "balanced": "ï‰ژ",
        "power-saver": "ïپ¬"
      }
    },
    
    // network
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{icon}",
        "format-ethernet": "َ°Œک",
        "tooltip-format": "Network: <big><b>{essid}</b></big>\nSignal strength: <b>{signaldBm}dBm ({signalStrength}%)</b>\nFrequency: <b>{frequency}MHz</b>\nInterface: <b>{ifname}</b>\nIP: <b>{ipaddr}/{cidr}</b>\nGateway: <b>{gwaddr}</b>\nNetmask: <b>{netmask}</b>",
        "format-linked": "َ°ˆ€ {ifname} (No IP)",
        "format-disconnected": "َ°–ھ ",
        "tooltip-format-disconnected": "Disconnected",
        "interval": 2,
        "max-length": 30,
    	"format-icons": [
    		"َ°¤¯", "َ°¤ں", "َ°¤¢", "َ°¤¥", "َ°¤¨"
    	],
        "on-click-right": "kitty -e nmtui"
    },

    // network speed
    "network#speed": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format": "<span foreground='#1e1e2e'>ï€™ {bandwidthDownBytes}</span> <span foreground='#11111b'>ï‚“ {bandwidthUpBytes}</span>",
        "format-disconnected": "َ°–ھ ",
        "tooltip": false,
        "interval": 1,
        "max-length": 30,
    	"format-icons": [
    		"َ°¤¯", "َ°¤ں", "َ°¤¢", "َ°¤¥", "َ°¤¨"
    	],
        "on-click-right": "kitty -e nmtui"
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "start-activated": true,
            "format-icons": {
                "activated": "î°•",
                "deactivated": "َ°›ٹ"
            },
        "tooltip-format-activated":"Caffeine Mode: Active \nNothing will be happen.",
        "tooltip-format-deactivated":"Caffeine Mode: Inactive\n\nIf there is no interaction with your\nsystem (mouse/keyboard), then \nScreen Lock: after 5 min \nScreen Off: after 10 min \nSleep: after 30 min"
    },

    "hyprland/window": {
        "format": "{}",
        "separate-outputs": true,
        "rewrite": {
            "(.*)${USER}@${set_sysname}:(.*)": "$1 ï’‰ :$2",
            "(.*) â€” Mozilla Firefox": "$1 َ°ˆ¹",
            "(.*)Mozilla Firefox": "$1 Firefox َ°ˆ¹",
            "(.*) - Visual Studio Code": "$1 َ°¨‍",
            "(.*)Visual Studio Code": "$1 Code َ°¨‍",
            "(.*) â€” Dolphin": "$1 َ°‰‹",
            "(.*)Spotify.*": "$1 Spotify َ°“‡",
            "(.*)Steam": "$1 Steam َ°““",
            "(.*) - Discord": "$1 ï‡؟ ",
            "(.*?)-\\s*YouTube(.*)": "$1َ°—ƒ", 
            "(.*?\\s)YouTube(.*)": "$1YouTube َ°—ƒ"
        },
        "max-length": 50
    },


    "hyprland/language": {
        "interval": 1,
        "format": "î©¥ {}",
        "format-uk": "Uk",
        "format-en": "US"
    },

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "on-click": "activate",
        "on-scroll-up": "hyprctl dispatch workspace e-1",
        "on-scroll-down": "hyprctl dispatch workspace e+1",
        "format-icons": {
            //  "default": "ï„‘"
          },
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": []
        }
    },

    "custom/cpu-icon": {
        "format": "î°™",
        "tooltip": false
    },

    "cpu": {
        "interval": 10,
        "format": "{usage}%"
    },

    "custom/disk-icon": {
        "format": "ïƒ‡ ",
        "tooltip": false
    },

    "disk": {
        "interval": 30,
        "format": "{free}",
        "path": "/",
        "tooltip": true,
        "tooltip-format": "Storage - {used} used out of {total} on {path} ({percentage_used}%)"
    },

    "custom/memory-icon": {
        "format": "َ°¾… ",
        "tooltip": false
    },

    "memory": {
        "interval": 2,
        "format": "{used}GB",
        "max-length": 10,
        "tooltip": true,
        "tooltip-format": "î‰¦ {used:0.1f}GB/{total:0.1f}GB"
    },

    "custom/notify_icon": {
        "tooltip": false,
        "tooltip-format": "You have<span foreground='#4A6096'> {} </span>notifications.",
        "format": "{icon} ",
        "format-icons": {
            "notification": "ï‚¢<span foreground='red'><sup>ï‘„</sup></span>",
            "none": "ï‚¢",
            "dnd-notification": "ï‡·<span foreground='red'><sup>ï‘„</sup></span>",
            "dnd-none": "ï‡·",
            "inhibited-notification": "ï‚¢<span foreground='red'><sup>ï‘„</sup></span>",
            "inhibited-none": "ï‚¢",
            "dnd-inhibited-notification": "ï‡·<span foreground='red'><sup>ï‘„</sup></span>",
            "dnd-inhibited-none": "ï‡·"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "sleep 0.1 && swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true,
    },

    "custom/notify": {
        "tooltip": true,
        "tooltip-format": "You have<span foreground='#4A6096'> {} </span>notifications.",
        "format": "{}",
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "sleep 0.1 && swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true,
    },

    "backlight": {
        "interval": 2,
        "align": 0,
        "rotate": 0,
        "format": "{icon} {percent}%",
        "format-icons": [
            "îڈ• ",
            "îڈ— ",
            "îڈڑ ",
            "َ°ƒ‌ ",
            "َ°ƒ‍ ",
            "َ°ƒں ",
            "َ°ƒ  "
        ],
        "tooltip-format": "backlight {percent}%",
        "icon-size": 10,
        "on-click": "",
        "on-click-middle": "",
        "on-click-right": "",
        "on-update": "",
        "on-scroll-up": "~/.config/hypr/scripts/brightness.sh up",
        "on-scroll-down": "~/.config/hypr/scripts/brightness.sh down",
        "smooth-scrolling-threshold": 1
    },

    "tray": {
        "icon-size": 18,
        "spacing": 10
    },

    "clock": {
        "format": "ï€— {:%I:%M %p}",
        "format-alt": "َ°ƒ­ {:%dآ·%mآ·%Y}",
        "on-clock-right": "exec gnome-calendar",
        "tooltip": true,
        "tooltip-format": "<span>{calendar}</span>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "on-scroll": 1,
            "on-click-right": "mode",
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b>{}</b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_down",
            "on-scroll-down": "shift_up"
        }
    },

    "battery": {
	//"interval": 5,
	"align": 0,
	"rotate": 0,
	"full-at": 100,
	"design-capacity": false,
	"states": {
		"good": 95,
		"warning": 30,
		"critical": 15
	},
	"format": "{icon} {capacity}%",
	"format-charging": "ïƒ§ {capacity}%",
	"format-plugged": "َ±ک– {capacity}%",
	"format-alt-click": "click",
	"format-full": "{icon} Full",
	"format-alt": "{icon} {time}",
	"format-icons": [
		"َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"
	    ],
	"format-time": "{H}h {M}min",
	"tooltip": true,
	"tooltip-format": "{timeTo} {power}w"
    },

    "custom/pulseaudio_icon": {
        "format": "{icon}",
        "format-muted": "ï‘¦ ",
        "tooltip": false,
        "on-click": "~/.config/hypr/scripts/volumecontrol.sh --toggle",
        "on-click-right": "pavucontrol",
        "on-scroll-up": "~/.config/hypr/scripts/volumecontrol.sh --inc",
        "on-scroll-down": "~/.config/hypr/scripts/volumecontrol.sh --dec",
        "scroll-step": 5,
        "format-icons": {
            "headphone": "ï€¥",
            "hands-free": "ï€¥",
            "headset": "ï€¥",
            "phone": "ï‚•",
            "default": ["ï€¨ "]
        }
    },

    "pulseaudio": {
        "format": "{volume}%",
        "format-muted": "0%",
        "on-click": "~/.config/hypr/scripts/volumecontrol.sh --toggle",
        "on-click-right": "pavucontrol",
        "on-scroll-up": "~/.config/hypr/scripts/volumecontrol.sh --inc",
        "on-scroll-down": "~/.config/hypr/scripts/volumecontrol.sh --dec",
        "scroll-step": 5,
    },

    "custom/pulse_mic_icon": {
        "format": "ï„° "
    },

    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "{volume}%",
        "format-source-muted": "0%",
        "on-click": "pamixer --default-source -t",
        "on-click-right": "pavucontrol",
        "on-scroll-up": "pamixer --default-source -i 5",
        "on-scroll-down": "pamixer --default-source -d 5",
        "scroll-step": 5
    },

    "mpris": {
        "interval": 2,
        "format": "{player_icon}  {status_icon}",
        "format-paused": "{player_icon}  {status_icon}",
        "tooltip": true,
        "tooltip-format": "{dynamic}",
        "on-click": "playerctl play-pause",
        "on-click-middle": "playerctl previous",
        "on-click-right": "playerctl next",
        "scroll-step": 5.0,
        "on-scroll-up": "~/.config/hypr/scripts/volumecontrol.sh --inc",
        "on-scroll-down": "~/.config/hypr/scripts/volumecontrol.sh --dec",
        "smooth-scrolling-threshold": 1,
        "player-icons": {
            "chromium": "ï‰¨",
            "default": "ï€‌",
            "firefox": "ï‰©",
            "kdeconnect": "ïکں",
            "mopidy": "ï€پ",
            "mpv": "َ°گ¹",
            "spotify": "ï†¼",
            "vlc": "َ°•¼"
        },
        "status-icons": {
            "paused": "َ°ڈ¤ ",
            "playing": "ïپ‹ ",
            "stopped": "ïپچ"
        },
        "max-length": 30
    },
    
    "temperature": {
        "thermal-zone": 1,
        "format": "ï‹‰ {temperatureC}آ°C",
        "critical-threshold": 70,
        "format-critical": "ï‹‡ {temperatureF}آ°F",
        "on-click": "kitty --title btop sh -c 'btop'"
    },

    // "keyboard-state": {
	// "numlock": true,
	// "capslock": true,
	// "format": {
	// 	"numlock": "N {icon}",
	// 	"capslock": "َ°ھ› {icon}"
	//     },
	// "format-icons": {
	// 	"locked": "ï€£",
	// 	"unlocked": "ï‚œ"
	//     }
    // },

    // works for arch, fedora and opensuse also.
    "custom/updater_icon": {
        "exec": "~/.config/hypr/scripts/systemupdate.sh --check",
        "format" : "ï€™ ",
        "tooltip": "false",
        "interval": 86400 // once every day
    },

    "custom/updater": {
        "exec": "~/.config/hypr/scripts/systemupdate.sh --check",
        "return-type": "json",
        "format": "{}",
        "on-click": "~/.config/hypr/scripts/systemupdate.sh --update",
        "interval": 86400, // once every day
        "tooltip": true
    },

    "custom/cava": {
        "exec": "~/.config/hypr/scripts/cava.sh",
        "framerate": 60
    },

    "custom/clipboard_icon": {
        "format": "َ°…Œ",
        "on-click": "~/.config/hypr/scripts/cliphist.sh c",
        "on-click-right": "~/.config/hypr/scripts/cliphist.sh w",
        "tooltip": "false",
        "interval": 1
    },

    "custom/clipboard": {
        "format": "{}",
        "exec": "~/.config/hypr/scripts/cliphist.sh l",
        "on-click": "~/.config/hypr/scripts/cliphist.sh c",
        "on-click-right": "~/.config/hypr/scripts/cliphist.sh w",
        "tooltip": "true",
        "tooltip-format": "Item copied: {}",
        "interval": 1
    },

    "custom/nightlight": {
        "format": "َ°–” ",
        "exec": "~/.config/hypr/scripts/nightlight.sh",
        "on-scroll-down": "~/.config/hypr/scripts/nightlight.sh --dec",
        "on-scroll-up": "~/.config/hypr/scripts/nightlight.sh --inc",
        "on-click": "~/.config/hypr/scripts/nightlight.sh --value",
        "on-click-right": "~/.config/hypr/scripts/nightlight.sh --def",
        "tooltip": true,
        "tooltip-format": "Screen temperature is: {}\n\nLeft Click: set temp 5000k\nRight Click: set temp 6500k (default)\n\nScroll Down: increase temp(+100K)\nScroll Up: decrease temp(-100K)",
        "interval": 1
    },
}
